<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Student Finder</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: "Poppins", Arial, sans-serif;
    }

    body {
      min-height: 100vh;
      position: relative;
      overflow-x: hidden;
      background:
        linear-gradient(rgba(7, 15, 30, 0.72), rgba(7, 15, 30, 0.8)),
        url("https://images.unsplash.com/photo-1498243691581-b145c3f54a5a?auto=format&fit=crop&w=1600&q=80") center/cover no-repeat fixed;
      padding: 30px 15px;
      color: #fff;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background:
        radial-gradient(circle at top left, rgba(37, 99, 235, 0.28), transparent 35%),
        radial-gradient(circle at bottom right, rgba(6, 182, 212, 0.24), transparent 35%);
      pointer-events: none;
      z-index: 0;
    }

    .container {
      max-width: 1200px;
      margin: auto;
      position: relative;
      z-index: 1;
    }

    .hero {
      text-align: center;
      margin-bottom: 28px;
    }

    .hero h1 {
      font-size: 2.7rem;
      font-weight: 700;
      margin-bottom: 8px;
      letter-spacing: 0.5px;
    }

    .hero p {
      color: #e2e8f0;
      font-size: 1rem;
    }

    .panel {
      background: rgba(255, 255, 255, 0.14);
      border: 1px solid rgba(255, 255, 255, 0.18);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-radius: 22px;
      padding: 22px;
      box-shadow: 0 10px 35px rgba(0, 0, 0, 0.22);
      margin-bottom: 25px;
    }

    .filters {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 14px;
      align-items: end;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 7px;
    }

    .field label {
      font-size: 0.92rem;
      color: #f8fafc;
      font-weight: 500;
    }

    .field input,
    .field select {
      padding: 12px 14px;
      border-radius: 12px;
      border: none;
      outline: none;
      font-size: 0.96rem;
      background: rgba(255, 255, 255, 0.92);
      color: #0f172a;
    }

    .actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    button {
      border: none;
      padding: 12px 18px;
      border-radius: 12px;
      font-size: 0.95rem;
      cursor: pointer;
      transition: 0.25s ease;
      font-weight: 600;
    }

    .search-btn {
      background: #2563eb;
      color: white;
    }

    .search-btn:hover {
      background: #1d4ed8;
      transform: translateY(-1px);
    }

    .reset-btn {
      background: rgba(255, 255, 255, 0.9);
      color: #0f172a;
    }

    .reset-btn:hover {
      background: white;
      transform: translateY(-1px);
    }

    .top-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 18px;
      gap: 12px;
      flex-wrap: wrap;
    }

    .top-bar h2 {
      font-size: 1.2rem;
      font-weight: 600;
    }

    .count-badge {
      background: rgba(255, 255, 255, 0.18);
      padding: 8px 14px;
      border-radius: 999px;
      font-size: 0.92rem;
      color: #f8fafc;
    }

    .student-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 18px;
    }

    .card {
      background: rgba(255, 255, 255, 0.95);
      color: #0f172a;
      border-radius: 18px;
      padding: 18px;
      box-shadow: 0 12px 30px rgba(15, 23, 42, 0.16);
      transition: 0.3s ease;
      position: relative;
      overflow: hidden;
    }

    .card:hover {
      transform: translateY(-6px);
    }

    .card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 6px;
      background: linear-gradient(90deg, #2563eb, #06b6d4);
    }

    .profile {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 14px;
    }

    .avatar {
      width: 58px;
      height: 58px;
      border-radius: 50%;
      background: linear-gradient(135deg, #2563eb, #06b6d4);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      font-weight: 700;
      flex-shrink: 0;
    }

    .student-name {
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 3px;
    }

    .student-role {
      color: #475569;
      font-size: 0.9rem;
    }

    .details {
      display: grid;
      gap: 9px;
      margin-top: 10px;
    }

    .detail-item {
      background: #f8fafc;
      padding: 10px 12px;
      border-radius: 10px;
      font-size: 0.93rem;
      color: #334155;
    }

    .detail-item strong {
      color: #0f172a;
    }

    .empty-state {
      background: rgba(255, 255, 255, 0.92);
      color: #0f172a;
      text-align: center;
      border-radius: 18px;
      padding: 30px 20px;
      font-size: 1rem;
      box-shadow: 0 10px 24px rgba(0, 0, 0, 0.12);
    }

    @media (max-width: 768px) {
      .hero h1 {
        font-size: 2rem;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="hero">
      <h1>Student Search Portal</h1>
      <p>ENTER STUDENT NAME TO ACCESS STUDENT DETAIL OR FILTER</p>
    </div>

    <div class="panel">
      <div class="filters">
        <div class="field">
          <label for="searchInput">Search Student</label>
          <input type="text" id="searchInput" placeholder="Search by name..." />
        </div>

        <div class="field">
          <label for="classFilter">Class</label>
          <select id="classFilter">
            <option value="">All Classes</option>
            <option value="1st Year">1st Year</option>
            <option value="2nd Year">2nd Year</option>
            <option value="3rd Year">3rd Year</option>
            <option value="4th Year">4th Year</option>
          </select>
        </div>

        <div class="field">
          <label for="courseFilter">Course</label>
          <select id="courseFilter">
            <option value="">All Courses</option>
            <option value="BS-MS">BS-MS</option>
            <option value="B.Tech">B.Tech</option>
            <option value="BCA">BCA</option>
            <option value="BBA">BBA</option>
            <option value="B.Sc">B.Sc</option>
          </select>
        </div>

        <div class="field">
          <label for="cityFilter">City</label>
          <select id="cityFilter">
            <option value="">All Cities</option>
            <option value="Ghazipur">Ghazipur</option>
            <option value="Kanpur">Kanpur</option>
            <option value="Lucknow">Lucknow</option>
            <option value="Patna">Patna</option>
            <option value="Jaipur">Jaipur</option>
            <option value="Delhi">Delhi</option>
          </select>
        </div>

        <div class="field">
          <label>Actions</label>
          <div class="actions">
            <button class="search-btn" onclick="applyFilters()">Search</button>
            <button class="reset-btn" onclick="resetFilters()">Reset</button>
          </div>
        </div>
      </div>
    </div>

    <div class="top-bar">
      <h2>Student Records</h2>
      <div class="count-badge" id="studentCount">Total: 0</div>
    </div>

    <div id="result" class="student-grid"></div>
  </div>

  <script>
    const students = [
      {
        name: "Ashish Kushwaha",
        age: 19,
        classYear: "1st Year",
        course: "BS-MS",
        city: "Ghazipur",
        department: "Computer Science"
      },
      {
        name: "Manya Lath",
        age: 18,
        classYear: "1st Year",
        course: "BS-MS",
        city: "Patna",
        department: "Computer Science"
      },
      {
        name: "Rahul Verma",
        age: 20,
        classYear: "2nd Year",
        course: "B.Tech",
        city: "Lucknow",
        department: "Mechanical Engineering"
      },
      {
        name: "Sneha Singh",
        age: 21,
        classYear: "3rd Year",
        course: "B.Sc",
        city: "Delhi",
        department: "Mathematics"
      },
      {
        name: "Arjun Gupta",
        age: 22,
        classYear: "4th Year",
        course: "B.Tech",
        city: "Jaipur",
        department: "Civil Engineering"
      },
      {
        name: "Priya Sharma",
        age: 19,
        classYear: "1st Year",
        course: "BCA",
        city: "Kanpur",
        department: "Computer Applications"
      }
    ];

    const result = document.getElementById("result");
    const studentCount = document.getElementById("studentCount");
    const searchInput = document.getElementById("searchInput");
    const classFilter = document.getElementById("classFilter");
    const courseFilter = document.getElementById("courseFilter");
    const cityFilter = document.getElementById("cityFilter");

    function getInitials(fullName) {
      return fullName
        .split(" ")
        .map(word => word.charAt(0))
        .join("")
        .toUpperCase();
    }

    function createStudentCard(student) {
      return `
        <div class="card">
          <div class="profile">
            <div class="avatar">${getInitials(student.name)}</div>
            <div>
              <div class="student-name">${student.name}</div>
              <div class="student-role">${student.department}</div>
            </div>
          </div>

          <div class="details">
            <div class="detail-item"><strong>Age:</strong> ${student.age}</div>
            <div class="detail-item"><strong>Class:</strong> ${student.classYear}</div>
            <div class="detail-item"><strong>Course:</strong> ${student.course}</div>
            <div class="detail-item"><strong>City:</strong> ${student.city}</div>
          </div>
        </div>
      `;
    }

    function showInitialMessage() {
      result.innerHTML = `
        <div class="empty-state">
          ENTER STUDENT NAME TO ACCESS STUDENT DETAIL.
        </div>
      `;
      studentCount.textContent = "Total: 0";
    }

    function renderStudents(studentList) {
      if (studentList.length === 0) {
        result.innerHTML = `
          <div class="empty-state">
            No students found for the selected filters.
          </div>
        `;
        studentCount.textContent = "Total: 0";
        return;
      }

      result.innerHTML = studentList.map(createStudentCard).join("");
      studentCount.textContent = `Total: ${studentList.length}`;
    }

    function applyFilters() {
      const searchValue = searchInput.value.toLowerCase().trim();
      const selectedClass = classFilter.value;
      const selectedCourse = courseFilter.value;
      const selectedCity = cityFilter.value;

      const isAnyFilterApplied =
        searchValue !== "" ||
        selectedClass !== "" ||
        selectedCourse !== "" ||
        selectedCity !== "";

      if (!isAnyFilterApplied) {
        showInitialMessage();
        return;
      }

      const filteredStudents = students.filter(student => {
        const matchesSearch = student.name.toLowerCase().includes(searchValue);
        const matchesClass = selectedClass === "" || student.classYear === selectedClass;
        const matchesCourse = selectedCourse === "" || student.course === selectedCourse;
        const matchesCity = selectedCity === "" || student.city === selectedCity;

        return matchesSearch && matchesClass && matchesCourse && matchesCity;
      });

      renderStudents(filteredStudents);
    }

    function resetFilters() {
      searchInput.value = "";
      classFilter.value = "";
      courseFilter.value = "";
      cityFilter.value = "";
      showInitialMessage();
    }

    searchInput.addEventListener("input", applyFilters);
    classFilter.addEventListener("change", applyFilters);
    courseFilter.addEventListener("change", applyFilters);
    cityFilter.addEventListener("change", applyFilters);

    showInitialMessage();
  </script>
